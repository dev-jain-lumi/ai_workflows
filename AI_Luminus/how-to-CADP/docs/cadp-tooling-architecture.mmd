flowchart LR
  %% =========================================================
  %% LAYERS
  %% =========================================================

  subgraph GOV["Governance + Discovery"]
    PORTAL["Data Product<br/>Portal"]
    DPM["Data Product<br/>Manager"]
  end

  subgraph DEV["Developer Workspace"]
    IDE["ONA / VS Code<br/>Developer IDE"]
    GL["GitLab<br/>Source Control"]
  end

  subgraph BUILD["Build + Runtime"]
    VUL["Vulcan<br/>Runtime Config"]
    CICD["GitLab CI/CD<br/>Deployment Pipeline"]
    CON["Conveyor / Airflow<br/>Orchestration"]
  end

  subgraph TRANS["Transformation + Quality"]
    DBT["DBT<br/>Models + Tests"]
    SODA["Soda<br/>Data Quality Checks"]
  end

  subgraph DATA["Data Platform"]
    SF[("Snowflake<br/>Schemas, Tables, Views")]
  end

  %% =========================================================
  %% MAIN FLOW
  %% =========================================================

  PORTAL -->|"*access request<br/>metadata*"| DPM
  DPM -->|"*schema + grants*"| SF

  IDE -->|"*commit / push*"| GL
  GL -->|"*pull / clone*"| IDE

  IDE -->|"*develop models*"| DBT
  IDE -->|"*edit config*"| VUL
  VUL -->|"*version config*"| GL

  GL -->|"*trigger pipeline*"| CICD
  VUL -->|"*runtime params*"| CICD
  CICD -->|"*deploy jobs*"| CON
  CON -->|"*run models*"| DBT

  DBT -->|"*write outputs*"| SF
  DBT -->|"*quality rules*"| SODA
  SODA -->|"*audit data*"| SF
  SODA -->|"*quality gate*"| CICD
  CICD -->|"*publish step*"| SF

  SF -->|"*expose products*"| PORTAL
  DPM -->|"*publish metadata*"| PORTAL
  SF -->|"*atomic clone*"| SF

