  classDef dbt fill:#6B46C1,stroke:#2C591B,color:#FFFFFF;
  classDef soda fill:#D53F8C,stroke:#2C591B,color:#FFFFFF;
  classDef snowflake fill:#E6F0FF,stroke:#2C591B,color:#1F2A1F;

  class GOV,DEV,BUILD,TRANS,DATA frame;
  class PORTAL portal;
  class DPM dpm;
  class IDE ide;
  class GL gitlab;
  class VUL vulcan;
  class CICD cicd;
